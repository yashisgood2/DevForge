# Postgres
POSTGRES_USER=devforge
POSTGRES_PASSWORD=devforge123
POSTGRES_DB=devforge_db
DATABASE_URL=postgresql://devforge:devforge123@localhost:5432/devforge_db

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_MANAGEMENT_URL=http://localhost:15672

# JWT
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Services (internal URLs — used by gateway to proxy)
AUTH_SERVICE_URL=http://localhost:5001
WORKSPACE_SERVICE_URL=http://localhost:4001
PROJECT_SERVICE_URL=http://localhost:4002

# Gateway
PORT=3000
NODE_ENV=development